# Copy to .env (do NOT commit .env)
#
# Volcengine / Huoshan (Ark) API settings
VOLC_API_KEY=your_api_key_here
VOLC_BASE_URL=https://ark.cn-beijing.volces.com
VOLC_MODEL=

# Optional: LLM gating
# - smart: call LLM when fast rules are not "high risk" (default)
# - always: call LLM for every comment (more expensive; good for debugging)
# - off / fast_only: do not call LLM (rules only)
VOLC_LLM_MODE=smart
VOLC_TIMEOUT_S=12

# Optional: map 0-100 risk_score -> LOW/MED/HIGH
SEVERITY_LOW_MAX=34
SEVERITY_MED_MAX=69

